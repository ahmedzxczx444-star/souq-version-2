# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# JWT_SECRET: Secret key for signing JWT tokens.
JWT_SECRET="your-super-secret-key"

# RECAPTCHA_SECRET: Google reCAPTCHA v2 server-side secret key.
RECAPTCHA_SECRET="your-recaptcha-secret-key"

# VITE_RECAPTCHA_SITE_KEY: Google reCAPTCHA v2 client-side site key.
VITE_RECAPTCHA_SITE_KEY="your-recaptcha-site-key"

# BREVO_API_KEY: Brevo (Sendinblue) transactional email REST API key.
# Required to send OTP verification emails. Without it, OTPs are only logged
# to the server console (local/dev fallback) and no real email is sent.
BREVO_API_KEY="your-brevo-api-key"

# BREVO_SENDER_EMAIL / BREVO_SENDER_NAME: verified Brevo sender identity used
# as the "from" address for OTP emails. Optional — defaults shown below.
BREVO_SENDER_EMAIL="no-reply@souqcars.com"
BREVO_SENDER_NAME="Souq Cars"
